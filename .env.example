# Employee001 — environment template
# Copy this to `.env` (or `.env.local`) and fill in your keys.
# Or run `npx employee001 setup` to do it interactively.
#
# This build runs on the 100%-Microsoft stack:
#   - Reasoning: Azure OpenAI Foundry (gpt-4o deployment)
#   - Tool layer: Microsoft Graph (Outlook / Teams / OneDrive / Planner / ToDo)
#   - Storage: Microsoft Fabric Lakehouse (OneLake) — local JSON fallback
#   - Voice: Azure Speech (Cognitive Services)
#
# Every Azure call uses AAD bearer tokens via DefaultAzureCredential. There is
# no static OpenAI API key — the Foundry has disableLocalAuth=true.

# ─── Required: Azure tenant + service principal ────────────────────────────────
# Entra app reg with delegated Graph permissions (User.Read, Mail.ReadWrite,
# Mail.Send, Files.ReadWrite.All, Tasks.ReadWrite, ChannelMessage.Send,
# Chat.ReadWrite, offline_access). Configured with isFallbackPublicClient=true.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# Used by DefaultAzureCredential (ClientSecretCredential). For local dev you
# can omit this and run `az login` instead — DefaultAzureCredential will fall
# through to AzureCliCredential.
AZURE_CLIENT_SECRET=

# ─── Required: Azure OpenAI Foundry ────────────────────────────────────────────
# Endpoint of the Foundry that hosts your gpt-4o deployment.
AZURE_OPENAI_ENDPOINT=https://<your-foundry>.cognitiveservices.azure.com/
# Deployment name (the underlying model is gpt-5.1; uses max_completion_tokens).
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# ─── Optional: Microsoft Fabric Lakehouse ──────────────────────────────────────
# When STORAGE_BACKEND=fabric, audit / twin-memory / org-brain writes mirror
# to the named lakehouse via OneLake DFS. The SP under AZURE_CLIENT_ID needs
# Contributor role on the workspace.
STORAGE_BACKEND=local
FABRIC_WORKSPACE_ID=
FABRIC_LAKEHOUSE_ID=
FABRIC_ONELAKE_PATH=https://onelake.dfs.fabric.microsoft.com/<workspace>/<lakehouse>.Lakehouse/Files

# ─── Optional: Azure Speech (Cognitive Services) ──────────────────────────────
# Powers /api/tts and /api/tts/stream. Region must match the speech resource.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SPEECH_VOICE=en-US-AvaMultilingualNeural

# ─── Optional: web search backend for the twin's WebSearch tool ───────────────
# Set one of these to give the twin a live search surface. Without one,
# WebSearch returns "not configured" and the twin answers from profile/brain
# only. WebFetch (single-URL fetch) works without a key.
TAVILY_API_KEY=
BING_SEARCH_KEY=

# ─── Networking + auth ────────────────────────────────────────────────────────
# Bind address. Default 127.0.0.1 (only this machine can reach the app).
# Set to 0.0.0.0 to expose on your LAN — use a firewall or Tailscale!
EMPLOYEE001_BIND=127.0.0.1

# Shared-secret access token. Required when EMPLOYEE001_BIND is non-loopback;
# ignored when bound to 127.0.0.1. `npx employee001 setup` generates one
# automatically — only set this manually if you're skipping the wizard.
EMPLOYEE001_TOKEN=

# Local server port.
PORT=3000
